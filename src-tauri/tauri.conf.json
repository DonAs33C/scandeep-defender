{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScanDeep Defender",
  "version": "1.0.0",
  "identifier": "com.scandeep",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "ScanDeep Defender",
        "width": 1200,
        "height": 820,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
